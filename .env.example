# ============================================================================
# Jobs Finder Agent — environment variables
# Copy to `.env` for local dev. In production these live in GitHub Actions
# Secrets (pipeline) and Cloudflare Pages env vars (dashboard).
# NEVER commit real values. All keys here are NEW and unique to this project.
# ============================================================================

# ---- LLM (default provider: groq) ------------------------------------------
# LLM_PROVIDER: groq | openai | anthropic | openrouter
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile
# Failover: comma-separated keys. On a 429/limit the adapter rotates to the next.
# (LLM_API_KEYS wins; LLM_API_KEY is a single-key fallback.)
LLM_API_KEYS=
LLM_API_KEY=
# Optional: override base URL (e.g. custom OpenAI-compatible gateway)
# LLM_BASE_URL=

# ---- Job sources -----------------------------------------------------------
# Adzuna (free tier) — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Adzuna country code for the search endpoint (gb, us, ca, au, de, ...)
ADZUNA_COUNTRY=gb
# Jooble (free key) — https://jooble.org/api/about
JOOBLE_KEY=
# Remotive / RemoteOK need NO key.
# Apify (paid credits, throttled) — https://apify.com/
APIFY_TOKEN=
# Apify actor id for a LinkedIn/Indeed job scraper (e.g. "bebity~linkedin-jobs-scraper")
APIFY_ACTOR=

# ---- Telegram delivery (NEW bot via @BotFather) ----------------------------
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ---- Cloudflare KV (pipeline writes via REST) ------------------------------
CF_API_TOKEN=
CF_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=

# ---- CV PDF hosting: public GitHub Pages repo ------------------------------
# A fine-grained PAT with contents:write on the job-cvs repo only.
CVS_DEPLOY_TOKEN=
# owner/repo, e.g. yourname/job-cvs
CVS_REPO=
# Public Pages base URL, e.g. https://yourname.github.io/job-cvs
CVS_BASE_URL=

# ---- Dashboard auth (self-built; set in Cloudflare Pages, not here) ---------
# Generate hash with: cd webapp && npm run hash-password
AUTH_USER=
AUTH_PASSWORD_HASH=
AUTH_SECRET=

# ---- Dashboard "Run now" (Cloudflare Pages env var) ------------------------
# Fine-grained GitHub PAT with actions:write on the CODE repo only.
GITHUB_PAT=
# owner/repo of the code repo, e.g. yourname/jobs-finder-agent
CODE_REPO=

# ---- Runtime flags ---------------------------------------------------------
# Set by GitHub Actions automatically; leave blank locally for no-op cloud.
CI=
